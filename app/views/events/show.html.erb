<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      
      <div class="border-bottom pb-3 mb-4">
        <span class="badge bg-primary mb-2">イベント管理画面</span>
        <h2 class="fw-bold text-dark"><%= @event.title %></h2>
      </div>

      <div class="card shadow-sm mb-5">
        <div class="card-header bg-light">
          <h5 class="card-title mb-0 fs-6 fw-bold text-muted">イベントの概要・メモ</h5>
        </div>
        <div class="card-body">
          <p class="card-text text-secondary lh-lg" style="white-space: pre-wrap;"><%= @event.desc %></p>
        </div>
      </div>
      <div class="card shadow-sm mb-5">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0 fs-6 fw-bold text-muted">出欠に使う日程の候補</h5>
        </div>
        <div class="card-body">
          
          <% if @event.candidate_dates.any? %>
            <ul class="list-group mb-4">
              <% @event.candidate_dates.each do |cd| %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <span class="fw-bold text-secondary">
                    <%= cd.date.strftime("%Y年%m月%d日") %> </span>
                  
                  <%= link_to '削除', [@event, cd], data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }, class: 'btn btn-outline-danger btn-sm' %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-muted small mb-4">候補日がまだ登録されていません。下から追加してください。</p>
          <% end %>

          <hr>

          <h6 class="fw-bold text-secondary mb-3">候補日の追加</h6>
          <%= form_with model: [@event, CandidateDate.new], class: "row g-2 align-items-center" do |f| %>
            <div class="col-auto">
              <%= f.date_field :date, class: "form-control" %>
            </div>
            <div class="col-auto">
              <%= f.submit '追加する', class: "btn btn-success" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>